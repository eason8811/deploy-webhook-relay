# GitHub WebHook Secret. Must match the secret configured in GitHub deploy repo webhook.
WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Only react to deploy repo main branch push events.
DEPLOY_REF=refs/heads/main
DEPLOY_REPOSITORY=eason8811/apex-camp-deploy

# Only trigger when deploy repo changed files are under this prefix.
TEST_PREFIX=environments/test/

# Copy from Arcane UI: ApexCamp Test -> WebHooks -> GitOps Sync trigger URL.
ARCANE_TEST_WEBHOOK_URL=CHANGE_ME_ARCANE_TEST_GIT_SYNC_WEBHOOK_URL

# Start with true for safe testing. Change to false after verification.
DRY_RUN=true

HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO

# Actual Docker network used by the Arcane-managed test stack.
# Confirm with: docker network ls | grep apex-camp-test
TEST_DOCKER_NETWORK=apex-camp-test_apex-camp-test-net
