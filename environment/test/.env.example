# GitHub WebHook Secret. Must match the secret configured in GitHub deploy repo webhook.
WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Only react to deploy repo main branch push events.
DEPLOY_REF=refs/heads/main
DEPLOY_REPOSITORY=eason8811/apex-camp-deploy

# Only trigger when deploy repo changed files are under this prefix.
TEST_PREFIX=environments/test/

# Copy from Arcane UI: ApexCamp Test -> WebHooks -> GitOps Sync trigger URL.
ARCANE_TEST_WEBHOOK_URL=CHANGE_ME_ARCANE_TEST_GIT_SYNC_WEBHOOK_URL

# Arcane Git Sync is synchronous. Keep connect failures short but allow the sync to finish.
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_TIMEOUT_SECONDS=600

# Fine-grained GitHub token scoped to the deploy repository with Pull requests: read.
# If lookup fails, the relay falls back to parsing "Merge pull request #...".
GITHUB_TOKEN=
GITHUB_API_TIMEOUT_SECONDS=5
GITHUB_API_VERSION=2026-03-10

# Email notifications. Credentials stay in the untracked .env file.
EMAIL_ENABLED=false
RELAY_ENVIRONMENT_NAME=ApexCamp Test
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=developers@apexcamp.net
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=developers@apexcamp.net
SMTP_TO_ADDRESSES=recipient-one@example.com,recipient-two@example.com
SMTP_TLS_MODE=ssl
SMTP_TIMEOUT_SECONDS=10
EMAIL_TIMEZONE=Asia/Shanghai
ARCANE_APP_URL=https://arcane.apexcamp.net
EMAIL_LOGO_URL=https://arcane.apexcamp.net/api/app-images/logo-email

# Start with true for safe testing. Change to false after verification.
DRY_RUN=true
LOG_LEVEL=INFO

# Actual Docker network used by the Arcane-managed test stack.
# Confirm with: docker network ls | grep apex-camp-test
TEST_DOCKER_NETWORK=apex-camp-test_apex-camp-test-net
