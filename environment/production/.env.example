# GitHub WebHook Secret. Must match the secret configured in GitHub deploy repo webhook.
WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Only react to deploy repo main branch push events.
DEPLOY_REF=refs/heads/main

# Production path filters.
CORE_PREFIX=environments/production/core/
PORTAL_PREFIX=environments/production/portal-111/

# Copy from Arcane WebHook UI.
# Recommended: use the full Arcane trigger URL first, e.g.
# https://arcane.apexcamp.net/api/webhooks/trigger/...
ARCANE_CORE_WEBHOOK_URL=CHANGE_ME_ARCANE_CORE_GIT_SYNC_WEBHOOK_URL
ARCANE_PORTAL_WEBHOOK_URL=CHANGE_ME_ARCANE_PORTAL_GIT_SYNC_WEBHOOK_URL

# Start with true for safe testing. Change to false after verification.
DRY_RUN=true

HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
